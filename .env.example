USER_AGENT=podrush/0.1
FEED_REFRESH_MAX_AGE_HOURS=24
MAX_SLUG_LEN=40
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_api_key_here
# Optional alternative to GEMINI_API_KEY
GOOGLE_API_KEY=

# Static private podcast publishing
PODRUSH_PUBLIC_BASE_URL=https://mydomain.com/data/podrush
PODRUSH_FEED_FILENAME=podrush-feed.xml
PODRUSH_FEED_TITLE=Podrush Private Podcast
PODRUSH_FEED_DESCRIPTION=Speed-adjusted podcast episodes generated by Podrush.
PODRUSH_UPLOAD_TARGET=user@host:/path/to/data/podrush/
